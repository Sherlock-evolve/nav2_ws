        <collision name="collision"><geometry><box><size>0.45 0.75 0.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.45 0.75 0.5</size></box></geometry></visual>
      </link>
    </model>

    <model name="unmapped_goal_obstacle">
