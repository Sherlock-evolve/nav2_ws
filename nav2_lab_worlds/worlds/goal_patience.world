        <visual name="visual"><geometry><box><size>4.2 0.12 0.5</size></box></geometry></visual>
      </link>
    </model>
    <model name="east_wall">
      <static>true</static>
      <pose>2 0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.12 4.2 0.5</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.12 4.2 0.5</size></box></geometry></visual>
